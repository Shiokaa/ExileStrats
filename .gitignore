# ----- dependencies (lourd, jamais versionné) -----
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ----- build / output Next.js (régénérable, lourd) -----
/.next/
/out/
/build
/dist
*.tsbuildinfo
next-env.d.ts

# ----- tests / couverture -----
/coverage
/.nyc_output

# ----- env & secrets (NE JAMAIS committer) -----
.env
.env.*
!.env.example

# ----- déploiement -----
/.vercel

# ----- logs / debug -----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ----- caches outils -----
/.eslintcache
/.cache
/.turbo

# ----- OS / éditeurs -----
.DS_Store
Thumbs.db
*.pem
.idea/
.vscode/*
!.vscode/extensions.json

# ----- graphify : fichiers machine & cache (régénérables) -----
# On garde graph.json / GRAPH_REPORT.md / manifest.json comme contexte partagé,
# mais on ignore tout ce qui est local-machine ou volumineux.
/graphify-out/cache/
/graphify-out/.graphify_python
/graphify-out/.graphify_root
/graphify-out/.needs_update
