# ── Database (Supabase Postgres) ────────────────────────────────────────────
# Copy this file to `.env` and fill in your real values. `.env` is gitignored —
# NEVER commit real credentials.
#
# In the Supabase dashboard: Project → Settings → Database → Connection string.
#  - DATABASE_URL = the "Transaction" pooler URL (host …pooler.supabase.com, port 6543).
#    Used by the app at runtime (serverless-friendly).
#  - DIRECT_URL   = the "Direct connection" URL (port 5432). Used by Prisma migrations.
#
# If you hit prepared-statement errors with the transaction pooler, use the
# "Session" pooler URL for DATABASE_URL instead.

DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"
